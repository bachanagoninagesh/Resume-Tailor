OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
REQUEST_TIMEOUT_SECONDS=120

# ── Brevo (recommended for Render — free 300 emails/day, no SMTP port needed) ─
# 1. Sign up at https://app.brevo.com
# 2. Go to Profile → SMTP & API → API Keys → Generate a new API key
# 3. Go to Senders & IPs → Senders → Add your Gmail as a verified sender
BREVO_API_KEY=your_brevo_api_key_here
EMAIL_FROM=your_email@gmail.com
DEFAULT_EMAIL_TO=your_email@gmail.com

# ── SMTP (works locally, blocked on Render) ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
SMTP_USE_STARTTLS=true
